# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Contest database (regenerated from seed CSVs; holds live predictions locally)
data/*.db
data/*.db-journal

# Local secrets — never commit (DATABASE_URL, ADMIN_PASSWORD)
.streamlit/secrets.toml

# Generated dashboard / export artifacts — regenerated by the admin
# "Refresh dashboards" action. Never commit, so local/sample data can't leak
# into a PR or overwrite the live dashboard.
exports/
dashboard/data.json